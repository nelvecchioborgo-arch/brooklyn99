# Credenziali PostgreSQL (dev)
POSTGRES_USER=PostGre
POSTGRES_PASSWORD=Password-Robusta
POSTGRES_DB=family-smart

# IP LAN del PC che ospita il container PostgreSQL
# ⚠️ Usa sempre l'IP LAN, perché funziona sia sul PC host che sugli altri
POSTGRES_HOST_IP=192.168.187.168

# Porta esposta dall'host (mappata da Docker)
POSTGRES_HOST_PORT=5432

# Connection string da usare nelle app (FastAPI, script, ecc.)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST_IP}:${POSTGRES_HOST_PORT}/${POSTGRES_DB}
